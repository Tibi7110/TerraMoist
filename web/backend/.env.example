# Copernicus Data Space Ecosystem (CDSE) OAuth2 credentials.
# Create an OAuth client at: https://dataspace.copernicus.eu
#   Dashboard → User Settings → OAuth Clients → Add Client
#
# Copy this file to .env and fill in your credentials.

CDSE_CLIENT_ID=your-oauth-client-id-here
CDSE_CLIENT_SECRET=your-oauth-client-secret-here

# Optional — defaults are correct for CDSE production.
# CDSE_TOKEN_URL=https://identity.dataspace.copernicus.eu/auth/realms/CDSE/protocol/openid-connect/token
# CDSE_PROCESS_URL=https://sh.dataspace.copernicus.eu/api/v1/process

# CORS — change if your frontend runs on a different port.
# FRONTEND_ORIGIN=http://localhost:5173
